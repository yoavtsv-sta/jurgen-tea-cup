# Stripe Payment Link (get from Stripe Dashboard → Payment Links → copy URL)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/your-payment-link

# Stripe secret key (get from Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret (get from Stripe Dashboard → Developers → Webhooks)
# Set webhook endpoint to: https://your-domain.com/api/webhooks/stripe
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend API key (get from resend.com → API Keys)
RESEND_API_KEY=re_...

# From address for order confirmation emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=hello@jurgenteacup.com
